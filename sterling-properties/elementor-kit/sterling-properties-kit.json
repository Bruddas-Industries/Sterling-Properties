          "elements": [
            {
              "id": "sp-cta-col",
              "elType": "column",
              "settings": {
                "width": { "size": 100, "unit": "%" },
                "text_align": "center"
              },
              "elements": [

                {
                  "id": "sp-cta-eyebrow",
                  "elType": "widget",
