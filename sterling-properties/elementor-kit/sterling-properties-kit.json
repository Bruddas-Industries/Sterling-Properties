    {
      "id": "sp-amenities",
      "title": "Amenities / Services Grid",
      "type": "page",
      "_comment": "3-column icon + heading + text card grid. Duplicate columns to add more items.",
      "content": [
        {
          "id": "sp-amenities-section",
          "elType": "section",
          "settings": {
            "layout": "boxed",
            "content_width": { "unit": "px", "size": 1280 },
            "background_background": "classic",
            "background_color": "var(--color-bg-alt)",
            "padding": {
              "unit": "rem",
              "top": "7", "right": "6", "bottom": "7", "left": "6"
            }
          },
          "elements": [

            {
              "id": "sp-amenities-intro-col",
              "elType": "column",
              "settings": { "width": { "size": 100, "unit": "%" } },
              "elements": [
                {
                  "id": "sp-amenities-eyebrow",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": { "editor": "<span class=\"eyebrow\">REPLACE_WITH_SECTION_LABEL</span>" }
                },
                {
                  "id": "sp-amenities-heading",
                  "elType": "widget",
                  "widgetType": "heading",
                  "_comment": "SECTION HEADING: 'Amenities', 'Services', or whatever fits the property.",
                  "settings": {
                    "title": "REPLACE_WITH_GRID_SECTION_HEADING",
