                    "editor": "<p style=\"color:var(--color-text-muted); line-height:1.75; max-width:44ch;\">REPLACE_WITH_FEATURE_BODY_TEXT</p>",
                    "margin": { "unit": "rem", "bottom": "2" }
                  }
                },
                {
                  "id": "sp-f2-cta",
