                  "settings": {
                    "editor": "<span class=\"eyebrow\" style=\"color:var(--color-primary);\">REPLACE_WITH_CTA_LABEL</span>"
                  }
                },

                {
                  "id": "sp-cta-heading",
                  "elType": "widget",
                  "widgetType": "heading",
                  "_comment": "CTA HEADING: Conversational, action-oriented. E.g. 'Ready to Call It Home?'",
