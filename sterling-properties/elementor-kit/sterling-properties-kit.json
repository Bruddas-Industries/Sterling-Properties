                    "padding": { "unit": "px", "top": "14", "right": "28", "bottom": "14", "left": "28" }
                  }
                }
              ]
            },

            {
              "id": "sp-f2-col-image",
              "elType": "column",
              "settings": {
                "width": { "size": 50, "unit": "%" },
                "background_background": "classic",
                "background_image": { "url": "REPLACE_WITH_IMAGE_URL" },
                "background_size": "cover",
                "background_position": "center center"
              },
              "elements": []
            }

          ]
        }
      ]
    },

